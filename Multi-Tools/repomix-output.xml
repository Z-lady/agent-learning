<body>

  <!-- HEADER -->
  <header>
    <div class="logo">
      <div class="logo-box">🤖</div>
      <div class="logo-name"><em>WEB</em> SEARCH AGENT</div>
    </div>
    <div class="header-right">
      <span class="model-badge">mistral-7b-instruct:free</span>
      <div class="status-pill" id="statusPill">
        <div class="dot" id="statusDot"></div>
        <span id="statusText">checking...</span>
      </div>
    </div>
  </header>

  <!-- MAIN -->
  <div class="main">

    <!-- CHAT -->
    <div class="chat-col">
      <div id="messages">
        <!-- Filled by JS -->
      </div>
      <div class="input-bar">
        <span class="prompt-arrow">›</span>
        <input id="inputBox" type="text" placeholder="Ask the agent anything..." autocomplete="off" />
        <button id="sendBtn">Run ↵</button>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">

      <div class="sidebar-section">
        <div class="sidebar-title">⚡ Loop Log</div>
        <div id="logList">
          <div class="log loop"><span class="ts">--:--</span>Waiting for input…</div>
        </div>
      </div>

      <div class="sidebar-section" style="flex:1; overflow:hidden; display:flex; flex-direction:column;">
        <div class="sidebar-title">📖 Key Concepts</div>
        <div class="concepts">
          <div class="concept-card">
            <div class="concept-title" style="color:#00d4ff">Tool Definition</div>
            <div class="concept-desc">JSON schema that tells the AI what tools exist and when to use them. Lives in
              <code style="font-family:monospace">agent.ts</code>.</div>
          </div>
          <div class="concept-card">
            <div class="concept-title" style="color:#a78bfa">Tool Execution</div>
            <div class="concept-desc">Your code that actually <em>runs</em> the tool when the AI requests it. The AI
              never runs it directly.</div>
          </div>
          <div class="concept-card">
            <div class="concept-title" style="color:#00ff88">Agent Loop</div>
            <div class="concept-desc">The <code style="font-family:monospace">while</code> loop that keeps asking the AI
              until <code style="font-family:monospace">finish_reason === "stop"</code>.</div>
          </div>
          <div class="concept-card">
            <div class="concept-title" style="color:#ff8c42">Message History</div>
            <div class="concept-desc">The array that stores every turn. This IS the agent's memory — send it every call.
            </div>
          </div>
        </div>
      </div>

      <div class="quick-asks">
        <div class="sidebar-title" style="padding:0 0 6px; border:none; font-size:9px">⚡ QUICK ASKS</div>
        <button class="chip" onclick="prefill('What are the best free AI agent frameworks in 2025?')">Best free agent
          frameworks 2025</button>
        <button class="chip" onclick="prefill('How does the ReAct agent pattern work?')">ReAct pattern
          explained</button>
        <button class="chip" onclick="prefill('What is RAG and why do agents need it?')">What is RAG?</button>
        <button class="chip" onclick="prefill('LangChain vs LangGraph — what is the difference?')">LangChain vs
          LangGraph</button>
      </div>

    </div>
  </div>

  <script>
    // ── STATE ─────────────────────────────────────────────────
    // history = the agent's memory across turns
    // Each message: { role, content, tool_calls?, tool_call_id? }
    let history = [];
    let busy = false;

    const msgEl = document.getElementById('messages');
    const logEl = document.getElementById('logList');
    const inputEl = document.getElementById('inputBox');
    const btnEl = document.getElementById('sendBtn');

    // ── STARTUP CHECK ─────────────────────────────────────────
    (async () => {
      try {
        const r = await fetch('/api/check');
        const { ok } = await r.json();
        const dot = document.getElementById('statusDot');
        const text = document.getElementById('statusText');

        if (ok) {
          dot.className = 'dot';
          text.textContent = 'online';
          showWelcome();
        } else {
          dot.className = 'dot offline';
          text.textContent = 'key missing';
          showKeyWarning();
        }
      } catch {
        showWelcome(); // server reachable, show welcome anyway
      }
    })();

    function showWelcome() {
      msgEl.innerHTML = `
    <div class="welcome">
      <div class="welcome-glyph">🔍</div>
      <h2>Agent is online.</h2>
      <p>Ask anything. The agent decides when to search the web, runs the tool, reads the results, and forms an answer — all autonomously.</p>
      <div class="welcome-flow">
        <span class="flow-step">question</span>
        <span class="flow-arrow">→</span>
        <span class="flow-step hl">tool call?</span>
        <span class="flow-arrow">→</span>
        <span class="flow-step">answer</span>
      </div>
    </div>`;
    }

    function showKeyWarning() {
      msgEl.innerHTML = `
    <div class="key-warning">
      <div style="font-size:36px">🔑</div>
      <h3>API Key Not Set</h3>
      <p>Open the <strong>.env</strong> file in the project root and paste your key:</p>
      <code>API_KEY=sk-or-v1-xxxx</code>
      <p style="font-size:12px">Get a free key at <strong>openrouter.ai/keys</strong> — no credit card needed.</p>
      <p style="font-size:12px">Then restart the server with <code style="font-family:monospace; background:#0d0508; padding:2px 6px; border-radius:4px">npm run dev</code>.</p>
    </div>`;
    }

    // ── HELPERS ───────────────────────────────────────────────
    function ts() {
      const n = new Date();
      return `${String(n.getHours()).padStart(2, '0')}:${String(n.getSeconds()).padStart(2, '0')}`;
    }

    function log(type, txt) {
      const d = document.createElement('div');
      d.className = `log ${type}`;
      d.innerHTML = `<span class="ts">${ts()}</span>${txt}`;
      logEl.appendChild(d);
      logEl.scrollTop = logEl.scrollHeight;
    }

    function clearWelcome() {
      const w = msgEl.querySelector('.welcome, .key-warning');
      if (w) w.remove();
    }

    function addMsg(role, text) {
      clearWelcome();
      const d = document.createElement('div');
      d.className = `msg ${role}`;
      const formatted = text
        .replace(/\n/g, '<br>')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/`(.*?)`/g, '<code style="font-family:monospace;background:#111;padding:1px 5px;border-radius:3px">$1</code>');
      d.innerHTML = `
    <div class="msg-label">${role === 'user' ? '👤 you' : '🤖 agent'}</div>
    <div class="msg-bubble">${formatted}</div>`;
      msgEl.appendChild(d);
      msgEl.scrollTop = msgEl.scrollHeight;
    }

    function addThinking(iter) {
      clearWelcome();
      removeThinking();
      const d = document.createElement('div');
      d.className = 'thinking';
      d.id = 'thinking';
      d.innerHTML = `<div class="spinner"></div> iteration ${iter} — calling AI…`;
      msgEl.appendChild(d);
      msgEl.scrollTop = msgEl.scrollHeight;
    }

    function removeThinking() {
      document.getElementById('thinking')?.remove();
    }

    let activeToolBody = null;

    function addToolCall(name, query) {
      clearWelcome();
      removeThinking();
      const d = document.createElement('div');
      d.className = 'tool-wrap';
      d.innerHTML = `
    <div class="tool-label">🔧 tool call</div>
    <div class="tool-card">
      <div class="tool-card-head">
        ⚡ executing
        <span class="tool-fn">${name}()</span>
      </div>
      <div class="tool-card-body">
        <span style="color:var(--muted2)">query →</span> "${query}"
      </div>
    </div>`;
      msgEl.appendChild(d);
      msgEl.scrollTop = msgEl.scrollHeight;
      activeToolBody = d.querySelector('.tool-card-body');
    }

    function addToolResult(preview) {
      if (!activeToolBody) return;
      const r = document.createElement('div');
      r.className = 'tool-result';
      r.textContent = '← ' + preview + (preview.length >= 200 ? '…' : '');
      activeToolBody.appendChild(r);
      msgEl.scrollTop = msgEl.scrollHeight;
    }

    // ── SEND ─────────────────────────────────────────────────
    async function send() {
      const text = inputEl.value.trim();
      if (!text || busy) return;

      busy = true;
      inputEl.value = '';
      btnEl.disabled = true;
      logEl.innerHTML = '';
      activeToolBody = null;

      addMsg('user', text);
      history.push({ role: 'user', content: text });
      log('loop', 'Agent loop started');

      try {
        const resp = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history }),
        });

        const reader = resp.body.getReader();
        const dec = new TextDecoder();
        let buf = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buf += dec.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop();

          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            let ev;
            try { ev = JSON.parse(line.slice(6)); } catch { continue; }

            if (ev.type === 'thinking') {
              log('loop', `Iteration ${ev.iteration} → calling AI`);
              addThinking(ev.iteration);
            }
            else if (ev.type === 'tool_call') {
              log('tool', `🔧 ${ev.name}("${ev.query.slice(0, 40)}")`);
              addToolCall(ev.name, ev.query);
            }
            else if (ev.type === 'tool_result') {
              log('tool', `↩ result (${ev.preview.length} chars)`);
              addToolResult(ev.preview);
            }
            else if (ev.type === 'answer') {
              removeThinking();
              addMsg('agent', ev.text);
              // Save to history for follow-up questions
              history.push({ role: 'assistant', content: ev.text });
              log('done', '✓ Complete');
            }
            else if (ev.type === 'error') {
              removeThinking();
              addMsg('agent', `⚠️ ${ev.message}`);
              log('err', ev.message);
            }
          }
        }
      } catch (err) {
        removeThinking();
        addMsg('agent', `⚠️ Network error: ${err.message}`);
        log('err', err.message);
      }

      busy = false;
      btnEl.disabled = false;
      inputEl.focus();
    }

    function prefill(q) { inputEl.value = q; inputEl.focus(); }

    // ── EVENTS ────────────────────────────────────────────────
    btnEl.addEventListener('click', send);
    inputEl.addEventListener('keydown', e => { if (e.key === 'Enter') send(); });
  </script>

</body>

