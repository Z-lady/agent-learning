<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Web Search Agent</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Outfit:wght@400;600;800&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --bg: #080b10;
      --panel: #0c1018;
      --card: #101520;
      --border: #1a2030;
      --border2: #243040;
